# Datenbank
DATABASE_URL="postgresql://postgres:password@localhost:5432/leadscout"

# Next.js
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Crawler API (interner Endpunkt zwischen Next.js und Python-Crawler)
CRAWLER_API_URL="http://localhost:8000"
CRAWLER_API_KEY="change-me-in-production"

# Optional: Proxy für Crawler (z.B. rotierender Proxy-Pool)
# CRAWLER_PROXY_URL=""

# Optional: Max. parallele Crawler-Anfragen
CRAWLER_MAX_CONCURRENT="3"
CRAWLER_DELAY_SECONDS="2"

# Nominatim (Geocoding) – nur öffentlicher Endpunkt, kein Key nötig
# Bei hohem Volumen eigene Instanz empfehlen
NOMINATIM_URL="https://nominatim.openstreetmap.org"

# Overpass API – öffentlicher Endpunkt, kein Key nötig
OVERPASS_URL="https://overpass-api.de/api/interpreter"

# Anthropic API – für KI Vertriebs-Research-Agent (ki_analyst.py)
# Ohne Key wird automatisch die Fallback-Analyse verwendet
ANTHROPIC_API_KEY=""
