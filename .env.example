# Datenbank
DATABASE_URL="postgresql://postgres:password@localhost:5432/leadscout"

# Next.js
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Crawler API (interner Endpunkt zwischen Next.js und Python-Crawler)
CRAWLER_API_URL="http://localhost:8000"
CRAWLER_API_KEY="change-me-in-production"

# Optional: Proxy für Crawler (z.B. rotierender Proxy-Pool)
# CRAWLER_PROXY_URL=""

# Optional: Max. parallele Crawler-Anfragen
CRAWLER_MAX_CONCURRENT="3"
CRAWLER_DELAY_SECONDS="2"
